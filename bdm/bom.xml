<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<businessObjectModel xmlns="http://documentation.bonitasoft.com/bdm-xml-schema/1.0" modelVersion="1.0">
    <businessObjects>
        <businessObject qualifiedName="com.hotel.model.ArticleCommandee">
            <fields>
                <field type="STRING" length="255" name="nom" nullable="true" collection="false"/>
                <field type="INTEGER" length="255" name="quantite" nullable="true" collection="false"/>
                <field type="INTEGER" length="255" name="prixUnitaire" nullable="true" collection="false"/>
            </fields>
            <uniqueConstraints/>
            <queries/>
            <indexes/>
        </businessObject>
        <businessObject qualifiedName="com.hotel.model.Categorie">
            <fields>
                <field type="STRING" length="255" name="nom" nullable="false" collection="false"/>
                <field type="INTEGER" length="255" name="tarif" nullable="false" collection="false"/>
            </fields>
            <uniqueConstraints/>
            <queries/>
            <indexes/>
        </businessObject>
        <businessObject qualifiedName="com.hotel.model.Chambre">
            <fields>
                <field type="STRING" length="255" name="numero" nullable="false" collection="false"/>
                <field type="BOOLEAN" length="255" name="propre" nullable="true" collection="false"/>
                <field type="BOOLEAN" length="255" name="occupe" nullable="true" collection="false"/>
                <relationField type="AGGREGATION" reference="com.hotel.model.Categorie" fetchType="EAGER" name="categorie" nullable="false" collection="false"/>
            </fields>
            <uniqueConstraints/>
            <queries>
                <query name="findAvailableRoomsByCategorie" content="SELECT c &#10;FROM Chambre c &#10;WHERE c.categorie.id = :categorieId&#10;AND c.propre = true&#10;AND c.occupe = false&#10;ORDER BY c.persistenceId ASC" returnType="java.util.List">
                    <queryParameters>
                        <queryParameter name="categorieId" className="java.lang.Long"/>
                    </queryParameters>
                </query>
            </queries>
            <indexes/>
        </businessObject>
        <businessObject qualifiedName="com.hotel.model.CommandeResto">
            <fields>
                <relationField type="AGGREGATION" reference="com.hotel.model.Reservation" fetchType="LAZY" name="reservation" nullable="true" collection="false"/>
                <relationField type="COMPOSITION" reference="com.hotel.model.ArticleCommandee" fetchType="EAGER" name="articlesCommandees" nullable="true" collection="true"/>
                <field type="INTEGER" length="255" name="total" nullable="true" collection="false"/>
                <field type="STRING" length="255" name="methodePaiement" nullable="true" collection="false"/>
                <field type="BOOLEAN" length="255" name="paye" nullable="true" collection="false"/>
            </fields>
            <uniqueConstraints/>
            <queries/>
            <indexes/>
        </businessObject>
        <businessObject qualifiedName="com.hotel.model.Reservation">
            <fields>
                <field type="TEXT" length="255" name="clientName" nullable="true" collection="false"/>
                <relationField type="AGGREGATION" reference="com.hotel.model.Chambre" fetchType="EAGER" name="chambre" nullable="true" collection="false"/>
                <field type="STRING" length="255" name="pieceIdentite" nullable="true" collection="false"/>
                <field type="BOOLEAN" length="255" name="paye" nullable="true" collection="false"/>
                <field type="STRING" length="255" name="statut" nullable="true" collection="false"/>
                <field type="INTEGER" length="255" name="coutTotalChambre" nullable="true" collection="false"/>
                <field type="INTEGER" length="255" name="nuitees" nullable="true" collection="false"/>
                <field type="INTEGER" length="255" name="restaurantExtras" nullable="true" collection="false"/>
                <relationField type="AGGREGATION" reference="com.hotel.model.Categorie" fetchType="EAGER" name="categorie" nullable="true" collection="false"/>
            </fields>
            <uniqueConstraints/>
            <queries>
                <query name="findActiveReservations" content="SELECT r &#10;FROM Reservation r &#10;WHERE r.statut = 'ACTIVE'&#10;ORDER BY r.persistenceId ASC" returnType="java.util.List">
                    <queryParameters/>
                </query>
            </queries>
            <indexes/>
        </businessObject>
    </businessObjects>
</businessObjectModel>
