        <defaultValue xmi:type="expression:Expression" xmi:id="_KbZKMVmuEfGcEbR76Q3nTg" name="init_currentOrder()" content="import com.hotel.model.CommandeResto;&#xA;import com.hotel.model.ArticleCommandee;&#xA;&#xA;def newCommande = new CommandeResto()&#xA;&#xA;newCommande.methodePaiement = methodePaiement;&#xA;&#xA;List&lt;ArticleCommandee> listItems = new ArrayList&lt;>();&#xA;def total = 0&#xA;articleCommandeesInput.each { inputRow ->&#xA;&#x9;def item = new ArticleCommandee();&#xA;&#x9;item.nom = inputRow.nom;&#xA;&#x9;item.quantite = inputRow.quantite != null ? inputRow.quantite.toInteger() : 0;&#xA;&#x9;item.prixUnitaire = inputRow.prixUnitaire != null ? inputRow.prixUnitaire.toInteger() : 0.0;&#xA;&#x9;&#xA;&#x9;total += item.prixUnitaire * item.quantite;&#xA;&#x9;listItems.add(item);&#xA;}&#xA;&#xA;newCommande.total = total;&#xA;newCommande.articlesCommandees = listItems;&#xA;return newCommande;" interpreter="GROOVY" type="TYPE_READ_ONLY_SCRIPT" returnType="com.hotel.model.CommandeResto">
