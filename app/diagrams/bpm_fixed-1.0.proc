            <rightOperand xmi:type="expression:Expression" xmi:id="_Lb4fElsoEfGecYGef2Fmwg" name="updateReservationStatutAndTotalCostAndRoomOccupe()" content="if (reservation.chambre != null) {&#xA;&#x9;reservation.chambre.setOccupe(true);&#xA;&#x9;&#xA;&#x9;reservation.setStatut(&quot;CONFIRME&quot;);&#xA;&#x9;int totalCost = reservation.getNuitees() * reservation.getCategorie().getTarif();&#xA;&#x9;reservation.setCoutTotalChambre(totalCost);&#xA;}&#xA;&#xA;return reservation;" interpreter="GROOVY" type="TYPE_READ_ONLY_SCRIPT" returnType="com.hotel.model.Reservation">
