        <defaultValue xmi:type="expression:Expression" xmi:id="_Oi4ukVmvEfGcEbR76Q3nTg" name="initReservation()" content="def reservationVar = new com.hotel.model.Reservation()&#xA;reservationVar.clientName = reservationInput?.client&#xA;reservationVar.pieceIdentite = reservationInput?.pieceIdentite&#xA;reservationVar.coutTotalChambre = reservationInput?.coutTotalChambre&#xA;reservationVar.nuitees = reservationInput?.nuitees&#xA;reservationVar.paye = false&#xA;reservationVar.coutTotalChambre = 0&#xA;reservationVar.restaurantExtras = 0&#xA;reservationVar.statut = &quot;EN ATTENTE&quot;&#xA;def categorieId = Long.parseLong(reservationInput?.categorieId)&#xA;reservationVar.categorie = {&#xA;&#x9;def categorieVar = categorieDAO.findByPersistenceId(categorieId)&#xA;&#x9;return categorieVar&#xA;}()&#xA;return reservationVar" interpreter="GROOVY" type="TYPE_READ_ONLY_SCRIPT" returnType="com.hotel.model.Reservation">
