        <defaultValue xmi:type="expression:Expression" xmi:id="_Oi4ukVmvEfGcEbR76Q3nTg" name="initReservation()" content="def reservationVar = new com.hotel.model.Reservation()&#xA;reservationVar.client = reservationInput?.client&#xA;reservationVar.pieceIdentite = reservationInput?.pieceIdentite&#xA;reservationVar.coutTotalChambre = reservationInput?.coutTotalChambre&#xA;reservationVar.nuitees = reservationInput?.nuitees&#xA;reservationVar.categorie = {&#xA;&#x9;//Retrieve aggregated Categorie using its DAO and persistenceId&#xA;&#x9;def categorieVar = categorieDAO.findByPersistenceId(reservationInput?.categorie?.persistenceId_string?.trim() ? reservationInput.categorie.persistenceId_string.toLong() : null)&#xA;&#x9;if (!categorieVar) {&#xA;&#x9;&#x9;if (reservationInput?.categorie?.persistenceId_string?.trim() ? reservationInput.categorie.persistenceId_string.toLong() : null) {&#xA;&#x9;&#x9;&#x9;throw new IllegalArgumentException(&quot;The aggregated reference of type `Categorie` with the persistence id &quot; + reservationInput?.categorie?.persistenceId_string?.trim() ? reservationInput.categorie.persistenceId_string.toLong() : null + &quot; has not been found.&quot;)&#xA;&#x9;&#x9;}&#xA;&#x9;&#x9;return null&#xA;&#x9;}&#xA;&#x9;return categorieVar}()&#xA;return reservationVar" interpreter="GROOVY" type="TYPE_READ_ONLY_SCRIPT" returnType="com.hotel.model.Reservation">
