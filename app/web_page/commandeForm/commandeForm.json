  "variables" : {
    "formInput" : {
      "type" : "json",
      "value" : [
        "{",
        "  \"methodePaiement\" : \"\",",
        "  \"articleCommandeesInput\" : [ ]",
        "}"
      ],
      "exposed" : false
    },
    "submit_errors_list" : {
      "type" : "expression",
      "value" : [
        "if($data.formOutput && $data.formOutput._submitError && $data.formOutput._submitError.explanations){",
        "\tconst liElements = $data.formOutput._submitError.explanations",
        "\t\t.filter(cause => cause !== null)",
        "\t\t.map(cause => \"<li>\" + cause + \"</li>\")",
        "\t\t.join('');",
        "\tif(liElements){",
        "\t\treturn \"<ul>\" + liElements + \"</ul>\";",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "formOutput" : {
      "type" : "expression",
      "value" : [
        "return {",
        "\tmethodePaiement: $data.formInput.methodePaiement,",
        "\tarticleCommandeesInput: $data.formInput.articleCommandeesInput",
        "}"
      ],
      "exposed" : false
    },
    "paymentMethods" : {
      "type" : "json",
      "value" : [
        "[",
        "    {\"key\": \"Paiement direct\", \"value\": \"DIRECT\"}, ",
        "    {\"key\": \"Transférer vers chambre\", \"value\": \"NOTE_CHAMBRE\"}",
        "]"
      ],
      "exposed" : false
    },
    "total" : {
      "type" : "expression",
      "value" : [
        "if (!$data.formInput || !$data.formInput.articleCommandeesInput) {",
        "    return 0;",
        "}",
        "",
        "return $data.formInput.articleCommandeesInput.reduce((acc, cur) => {",
        "    var qty = parseInt(cur.quantite) || 0;",
        "    var price = parseInt(cur.prixUnitaire) || 0;",
        "    return acc + (qty * price);",
        "}, 0);"
      ],
      "exposed" : false
    }
  },
